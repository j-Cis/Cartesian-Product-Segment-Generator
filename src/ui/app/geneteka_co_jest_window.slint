import { Palette } from "../theme/globals.slint";
import { WindowShell, CustomBtn } from "../components/window-shell.slint";
import { LineEdit } from "std-widgets.slint";

import { MapaKanwa, MapPoint } from "../components/mapa-kanwa.slint";
import { MapaKokpit, MapaCelownik } from "../components/mapa-kokpit.slint";

export { MapPoint } 

export component GenetekaCoJestWindow inherits WindowShell {
    preferred-width: 600px;
    preferred-height: 600px;
    window-title: "GENETEKA - CO JEST?";
    callback search(string);
    in property <[MapPoint]> map_points: [];
    in-out property <[string]> search_results: [];

    // ==========================================
    // BRAKUJĄCE ZMIENNE I FUNKCJE (PRZYWRÓCONE)
    // ==========================================
    in property <float> geo_min_lon;
    in property <float> geo_max_lon;
    in property <float> geo_min_lat;
    in property <float> geo_max_lat;
    pure function current_lat() -> string {
        let ratio = (-kanwa.map_offset_y + (kanwa.height / 2)) / (kanwa.height * kanwa.map_zoom);
        let val = geo_max_lat - (ratio * (geo_max_lat - geo_min_lat));
        return Math.round(val * 10000) / 10000 + "°";
    }
    pure function current_lon() -> string {
        let ratio = (-kanwa.map_offset_x + (kanwa.width / 2)) / (kanwa.width * kanwa.map_zoom);
        let val = geo_min_lon + (ratio * (geo_max_lon - geo_min_lon));
        return Math.round(val * 10000) / 10000 + "°";
    }
    // ==========================================

    VerticalLayout {
        padding: 20px;
        spacing: 15px;
        HorizontalLayout {
            spacing: 10px;
            height: 40px;
            input := LineEdit {
                placeholder-text: "Szukaj parafii...";
                accepted => {
                    root.search(self.text);
                }
            }

            CustomBtn {
                text: "SZUKAJ";
                width: 100px;
                primary: true;
                clicked => {
                    root.search(input.text);
                }
            }
        }

        kanwa := MapaKanwa {
            map_points: root.map_points;

            // 1. CELOWNIK I LICZNIK (Warstwa informacyjna)
            MapaCelownik {
                width: 100%;
                height: 100%;
                n_coord: root.current_lat();
                e_coord: root.current_lon();
                anchor: "ne"; // Licznik w prawym górnym rogu
            }

            // 2. KOKPIT (Warstwa sterowania)
            MapaKokpit {
                anchor: "sw";
                margin: 10px;
                x: (self.anchor == "nw" || self.anchor == "sw") ? self.margin : parent.width - self.preferred-width - self.margin;
                y: (self.anchor == "nw" || self.anchor == "ne") ? self.margin : parent.height - self.preferred-height - self.margin;
                zoom_in => {
                    kanwa.zoom_around_center(kanwa.map_zoom + 0.5);
                }
                zoom_out => {
                    kanwa.zoom_around_center(kanwa.map_zoom - 0.5);
                }
                rotate_ccw => {
                    kanwa.map_rotation -= 15deg;
                }
                rotate_cw => {
                    kanwa.map_rotation += 15deg;
                }
                pan(dx, dy) => {
                    kanwa.map_offset_x += dx;
                    kanwa.map_offset_y += dy;
                }
                reset => {
                    kanwa.map_zoom = 1.0;
                    kanwa.map_offset_x = 0px;
                    kanwa.map_offset_y = 0px;
                    kanwa.map_rotation = 0deg;
                }
            }
        }
    }
}
